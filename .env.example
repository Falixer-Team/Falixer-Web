# The Turnstile token used in development. Set to "0x4AAAAAAB7bNfQex8uoMyq6"
# if you use the production API and need to pass captchas.
TURNSTILE_PUBLIC=0x4AAAAAAD7wooI5Nvz97YQF
TURNSTILE_SECRET_KEY=

# 独立业务后端 API（供 Nuxt 服务端转发注册及找回密码请求）
BACKEND_API_BASE=http://localhost:8000/api

# SMTP（仅服务端读取，请勿使用 NUXT_PUBLIC_ 前缀）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=
SMTP_FROM=Falixer <no-reply@example.com>

# 邮箱验证码策略（秒）
EMAIL_CODE_EXPIRES_IN=600
EMAIL_CODE_RESEND_IN=60
EMAIL_CODE_MAX_ATTEMPTS=5

# License service URL.
# The lookup page requests GET {base}/query?target=panel.example.com
NUXT_PUBLIC_LICENSE_API_BASE=https://licences.falixer.dev
